    "print(f\"  Max frames per video: {MAX_FRAMES_PER_VIDEO}\")\n",
    "print(f\"  rPPG method: {RPPG_METHOD}\")\n",
    "print(f\"  Accuracy: Maximum precision via 9 rigorous spatial ROIs\")\n",
    "print(\"=\"*70)"
